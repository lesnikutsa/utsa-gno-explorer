# Install the real production file as /etc/utsa-gno-explorer/api.env.
# Replace the placeholder with a URL-safe password; never commit the real password.
# Keep API_BIND_HOST at 127.0.0.1 until a reverse proxy is configured.
# If API_BIND_PORT changes, update the later Nginx proxy target to match.
# A localhost-only listener needs no UFW rule.
DATABASE_URL=postgresql://utsa_gno_api:REPLACE_WITH_URL_SAFE_PASSWORD@127.0.0.1:5432/utsa_gno_explorer
API_BIND_HOST=127.0.0.1
API_BIND_PORT=18180
API_VERSION=0.8.0
API_INDEXER_LAG_DEGRADED_THRESHOLD=10
API_RPC_CHECK_STALE_SECONDS=60
API_LOG_LEVEL=info
