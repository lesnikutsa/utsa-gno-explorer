# Example only. Install the real file as /etc/utsa-gno-explorer/indexer.env.
# Do not commit real passwords or credential-bearing RPC URLs.
DATABASE_URL=postgresql://utsa_gno_indexer:REPLACE_WITH_PASSWORD@127.0.0.1:5432/utsa_gno_explorer
GNO_CHAIN_ID=topaz-1
GNO_RPC_URLS=https://rpc.topaz.testnets.gno.land,https://gnoland-testnet-rpc.itrocket.net,https://topaz.rpc.onbloc.xyz
RPC_MAX_HEIGHT_LAG=10
INDEXER_HARD_MAX_HEIGHTS=100
INDEXER_START_HEIGHT=1
INDEXER_BATCH_SIZE=50
INDEXER_POLL_INTERVAL_SECONDS=5
INDEXER_ERROR_BACKOFF_SECONDS=5
INDEXER_MAX_BACKOFF_SECONDS=60
LOG_LEVEL=INFO
